# Copy this file to .env and fill the values. DO NOT commit secrets.
# Example environment variables used by the application.

# Database
MONGO_URI=mongodb://localhost:27017
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# Stripe (put production keys in your secret store)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Environment
ENV=development
PORT=4000

# CORS
ALLOWED_ORIGINS=https://localhost:5173

# Optional
SPOTIFY_TOKEN=
CONFIG_URL=
